# Supabase (cloud) – Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT signing (REQUIRED in production; must be long + random)
APP_JWT_SECRET=CHANGE_ME_IN_PROD
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=15
APP_REFRESH_TOKEN_EXPIRE_DAYS=30

# Deployment environment: development | production | test
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins (REQUIRED in production)
# Example: https://www.midoraonline.com,https://midoraonline.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (SMTP)
Email=
Email_Password=
# Where to send internal "new shop submitted" notifications (comma-separated).
# Leave blank to fall back to the SMTP sender (above), i.e. email yourself.
ADMIN_NOTIFICATION_EMAIL=

# Public URLs used in outbound emails and OAuth redirects
API_BASE_URL=http://localhost:8000
EMAIL_VERIFICATION_FRONTEND_URL=http://localhost:3000/auth/verify-email

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_OAUTH_FRONTEND_CALLBACK_URL=http://localhost:3000/auth/callback

# AI
Gemini_API_Key=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Admin (REQUIRED in production)
ADMIN_API_KEY=

